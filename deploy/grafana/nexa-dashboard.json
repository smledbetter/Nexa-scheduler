  "panels": [
    {
      "title": "Scheduling Duration",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(nexa_scheduling_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.50, rate(nexa_scheduling_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "title": "Filter Results Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "rate(nexa_filter_results_total[5m])",
          "legendFormat": "{{plugin}} {{result}}"
        }
      ]
    },
    {
      "title": "Isolation Violations",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(increase(nexa_isolation_violations_total[1h]))",
          "legendFormat": "violations/hr"
        }
      ]
    },
    {
      "title": "Policy Evaluations Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 8},
      "targets": [
        {
          "expr": "rate(nexa_policy_evaluations_total[5m])",
          "legendFormat": "{{plugin}} {{result}}"
        }
      ]
    },
    {
      "title": "Score Distribution",
      "type": "histogram",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "nexa_score_distribution_bucket",
          "legendFormat": "{{plugin}}"
        }
      ]
    }
  ],
