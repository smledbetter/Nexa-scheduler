FROM golang:1.24 AS builder
WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /nexa-controller ./cmd/controller

FROM gcr.io/distroless/static:nonroot
COPY --from=builder /nexa-controller /nexa-controller
USER 65532:65532
ENTRYPOINT ["/nexa-controller"]
