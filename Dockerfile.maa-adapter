FROM golang:1.24 AS builder

WORKDIR /workspace

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /maa-adapter ./cmd/maa-adapter

FROM gcr.io/distroless/static:nonroot

COPY --from=builder /maa-adapter /maa-adapter

USER 65532:65532

ENTRYPOINT ["/maa-adapter"]
